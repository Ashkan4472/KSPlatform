# ============================================================================
# App runtime env (used by `npm run dev` / Prisma on the host)
# ============================================================================

# --- Database ---
# For local dev (app on host, Postgres in Docker): use localhost.
# Inside docker-compose the app builds this from the POSTGRES_* vars below.
DATABASE_URL="postgresql://ksuser:kspassword@localhost:5432/ksplatform?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST=true

# Optional: this email is auto-promoted to ADMIN on next login.
# (Roles can also be changed by hand in the DB.)
ADMIN_EMAIL=""

# --- S3 / MinIO object storage ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="ksplatform-uploads"
# Public base URL for uploaded objects (browser-reachable).
S3_PUBLIC_URL="http://localhost:9000/ksplatform-uploads"

# ============================================================================
# Docker Compose vars (read by docker-compose.yml for variable substitution)
# All have safe defaults, so `docker compose up` works without setting them —
# but you SHOULD override the credentials and AUTH_SECRET for any real deploy.
# ============================================================================

# Postgres
POSTGRES_USER="ksuser"
POSTGRES_PASSWORD="kspassword"
POSTGRES_DB="ksplatform"
POSTGRES_PORT="5432"

# MinIO (root creds double as the app's S3 access/secret key)
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_API_PORT="9000"
MINIO_CONSOLE_PORT="9001"

# App
APP_PORT="3000"
