{
  "name": "ksplatform-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:chrome",
    "build:chrome": "tsc --noEmit && vite build --outDir dist",
    "build:firefox": "tsc --noEmit && TARGET_BROWSER=firefox vite build --outDir dist-firefox",
    "package:chrome": "npm run build:chrome && rm -f ksplatform-extension-chrome.zip && cd dist && zip -qr ../ksplatform-extension-chrome.zip .",
    "package:firefox": "npm run build:firefox && rm -f ksplatform-extension-firefox.xpi && cd dist-firefox && zip -qr ../ksplatform-extension-firefox.xpi .",
    "package": "npm run package:chrome && npm run package:firefox",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@eslint/js": "^9.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/webextension-polyfill": "^0.12.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.20.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
